   "source": [
    "from sklearn.ensemble import IsolationForest\n",
    "import pandas as pd\n",
    "\n",
    "df = pd.DataFrame({\n",
    "    'Amount': [2800, 3200, 3500, 2900, 3100, 18000, 50]\n",
    "})\n",
    "\n",
    "model = IsolationForest(contamination=0.2, random_state=42)\n",
    "df['Anomaly'] = model.fit_predict(df)\n",
    "\n",
    "print(df)\n",
    "\n"
   ]
  },
